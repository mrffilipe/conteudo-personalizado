# Copie para .env e preencha (opcional — também pode colar a chave na interface)
VITE_OPENAI_API_KEY=
VITE_ANTHROPIC_API_KEY=
VITE_GEMINI_API_KEY=
# Em dev, use o proxy do Vite (evita CORS com LM Studio em :1234). Ex.: /lmstudio/v1
# Se deixar http://localhost:1234/v1, em modo dev o app redireciona para o proxy automaticamente.
VITE_LM_STUDIO_BASE_URL=/lmstudio/v1
API_PORT=5000
SCRAPE_TIMEOUT_MS=8000
SCRAPE_MAX_BYTES=2000000
CHECKPOINT_DIR=./data/checkpoints
OUTPUT_DIR=./data/output
